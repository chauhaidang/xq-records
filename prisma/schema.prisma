generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
}

model ObjectType {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  displayName String?  @map("display_name") @db.VarChar(200)
  description String?
  schemaJson  Json?    @map("schema_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  objects     Object[]

  @@index([name], map: "idx_object_types_name")
  @@map("object_types")
}

model Object {
  id               String          @id @default(cuid())
  objectTypeId     String          @map("object_type_id")
  externalKey      String          @map("external_key") @db.VarChar(200)
  originSource     String          @map("origin_source") @db.VarChar(200)
  status           String          @default("active") @db.VarChar(50)
  currentVersionId String?         @unique @map("current_version_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  objectType       ObjectType      @relation(fields: [objectTypeId], references: [id], onDelete: Restrict)
  currentVersion   ObjectVersion?  @relation("CurrentObjectVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions         ObjectVersion[] @relation("ObjectVersions")

  @@unique([objectTypeId, originSource, externalKey], map: "objects_identity_unique")
  @@index([objectTypeId], map: "idx_objects_object_type_id")
  @@index([originSource], map: "idx_objects_origin_source")
  @@index([status], map: "idx_objects_status")
  @@index([externalKey], map: "idx_objects_external_key")
  @@map("objects")
}

model ObjectVersion {
  id           String    @id @default(cuid())
  objectId     String    @map("object_id")
  version      Int
  data         Json
  changeReason String?   @map("change_reason")
  validFrom    DateTime  @default(now()) @map("valid_from")
  validTo      DateTime? @map("valid_to")
  createdAt    DateTime  @default(now()) @map("created_at")
  object       Object    @relation("ObjectVersions", fields: [objectId], references: [id], onDelete: Cascade)
  currentFor   Object?   @relation("CurrentObjectVersion")

  @@unique([objectId, version], map: "object_versions_object_version_unique")
  @@index([objectId], map: "idx_object_versions_object_id")
  @@index([validFrom], map: "idx_object_versions_valid_from")
  @@map("object_versions")
}
